#!/usr/bin/env bash
# pawpad VM startup script.
# Runs once at first boot via GCE metadata_startup_script. Idempotent — safe
# to re-run by clearing /var/lib/pawpad/.bootstrapped and rebooting.

set -euo pipefail

MARKER=/var/lib/pawpad/.bootstrapped
LOG=/var/log/pawpad-startup.log

exec > >(tee -a "$LOG") 2>&1
echo "===== pawpad startup at $(date -u) ====="

if [[ -f "$MARKER" ]]; then
  echo "already bootstrapped, exiting"
  exit 0
fi

mkdir -p /var/lib/pawpad

# --- create pawpad user ------------------------------------------------------

if ! id -u ${pawpad_user} >/dev/null 2>&1; then
  useradd --create-home --shell /bin/bash --groups sudo,docker ${pawpad_user}
  echo "${pawpad_user} ALL=(ALL) NOPASSWD: ALL" > /etc/sudoers.d/pawpad
  chmod 440 /etc/sudoers.d/pawpad
fi

# --- mount workspace disk ----------------------------------------------------

# Find the attached data disk. GCE exposes it as /dev/disk/by-id/google-pawpad-data.
DATA_DISK=/dev/disk/by-id/google-pawpad-data
MOUNT=/home/${pawpad_user}

if [[ -e "$DATA_DISK" ]]; then
  if ! blkid "$DATA_DISK" >/dev/null 2>&1; then
    echo "formatting $DATA_DISK as ext4"
    mkfs.ext4 -F "$DATA_DISK"
  fi
  UUID=$(blkid -s UUID -o value "$DATA_DISK")
  if ! grep -q "$UUID" /etc/fstab; then
    echo "UUID=$UUID  $MOUNT  ext4  defaults,nofail  0 2" >> /etc/fstab
  fi
  mkdir -p "$MOUNT"
  mount "$MOUNT" || true
  chown -R ${pawpad_user}:${pawpad_user} "$MOUNT"
fi

# --- install system packages -------------------------------------------------

apt-get update
DEBIAN_FRONTEND=noninteractive apt-get install -y \
  curl ca-certificates gnupg lsb-release \
  git build-essential \
  python3 python3-pip python3-venv \
  jq sqlite3 \
  software-properties-common

# --- node (for Quartz) -------------------------------------------------------

if ! command -v node >/dev/null 2>&1; then
  curl -fsSL https://deb.nodesource.com/setup_20.x | bash -
  apt-get install -y nodejs
fi

# --- docker (for Self-Hosted LiveSync CouchDB) -------------------------------

if ! command -v docker >/dev/null 2>&1; then
  install -m 0755 -d /etc/apt/keyrings
  curl -fsSL https://download.docker.com/linux/ubuntu/gpg | gpg --dearmor -o /etc/apt/keyrings/docker.gpg
  chmod a+r /etc/apt/keyrings/docker.gpg
  echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] https://download.docker.com/linux/ubuntu $(lsb_release -cs) stable" \
    | tee /etc/apt/sources.list.d/docker.list > /dev/null
  apt-get update
  apt-get install -y docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin
  usermod -aG docker ${pawpad_user}
fi

# --- gh cli ------------------------------------------------------------------

if ! command -v gh >/dev/null 2>&1; then
  curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg
  chmod go+r /usr/share/keyrings/githubcli-archive-keyring.gpg
  echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
    | tee /etc/apt/sources.list.d/github-cli.list > /dev/null
  apt-get update
  apt-get install -y gh
fi

# --- tailscale ---------------------------------------------------------------

if ! command -v tailscale >/dev/null 2>&1; then
  curl -fsSL https://tailscale.com/install.sh | sh
fi

systemctl enable --now tailscaled

if ! tailscale status >/dev/null 2>&1; then
  tailscale up \
    --authkey="${tailscale_authkey}" \
    --hostname="${tailscale_hostname}" \
    --advertise-tags=tag:pawpad \
    --ssh
fi

# --- claude code cli ---------------------------------------------------------

if ! command -v claude >/dev/null 2>&1; then
  sudo -u ${pawpad_user} bash -lc 'curl -fsSL https://claude.com/install.sh | bash'
  # Put claude on PATH for all users
  ln -sf /home/${pawpad_user}/.local/bin/claude /usr/local/bin/claude || true
fi

# --- clone pawpad repo to /opt/pawpad ----------------------------------------

if [[ ! -d /opt/pawpad/.git ]]; then
  mkdir -p /opt
  sudo -u ${pawpad_user} git clone --depth 1 --branch "${repo_ref}" "${repo_url}" /opt/pawpad
fi

chown -R ${pawpad_user}:${pawpad_user} /opt/pawpad

# --- python venv + deps ------------------------------------------------------

sudo -u ${pawpad_user} bash -lc '
  cd /opt/pawpad
  python3 -m venv .venv
  .venv/bin/pip install --quiet --upgrade pip
  .venv/bin/pip install --quiet -e .
'

# --- mark done ---------------------------------------------------------------

touch "$MARKER"
echo "===== pawpad startup complete at $(date -u) ====="
