# pawpad on-VM environment. The installer writes a real .env at /opt/pawpad/.env
# during deploy. Never commit secrets.

# --- Discord ---
DISCORD_TOKEN=
DISCORD_GUILD_ID=

# --- Anthropic ---
ANTHROPIC_API_KEY=

# --- Paths (defaults are fine on the VM) ---
PAWPAD_WORKSPACES=/home/pawpad/projects
PAWPAD_VAULT=/home/pawpad/obsidian-vault

# --- GitHub (only needed if not using gh CLI auth on VM) ---
# GH_TOKEN=

# --- LiveSync CouchDB ---
COUCHDB_USER=
COUCHDB_PASSWORD=

# --- Defaults / tuning ---
PAWPAD_SOFT_CAP=8
PAWPAD_IDLE_TIMEOUT_SECONDS=1800
PAWPAD_DEFAULT_DAILY_CAP_USD=500
OAUTH_DISCORD_URL=OAUTH_DISCORD_URL=https://discord.com/oauth2/authorize?client_id=1506688319491280976&permissions=2147601488&integration_type=0&scope=bot